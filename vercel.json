{
  "builds": [
    {
      "src": "api/transcript.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/transcript",
      "dest": "api/transcript.py"
    },
    {
      "src": "/",
      "dest": "index.html"
    }
  ]
}
